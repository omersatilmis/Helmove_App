# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  # ---- Xcode 27 / Swift 6.2 uyumu: RevenueCat PaywallColor.swift ----
  # Swift 6.2, optional stored property (_underlyingColor) için memberwise init'i
  # 'init(stringRepresentation:)' olarak sentezliyor ve extension'daki throwing
  # 'init(stringRepresentation:) throws' ile çakışıyor ("Invalid redeclaration of
  # synthesized memberwise init"). Struct gövdesine bir init eklenince memberwise
  # sentez bastırılır ve hata kalkar. RevenueCat upstream'de düzelene kadar yama.
  paywall_color = File.join(installer.sandbox.root, 'RevenueCat', 'Sources', 'Paywalls', 'PaywallColor.swift')
  if File.exist?(paywall_color)
    src = File.read(paywall_color)
    anchor = 'fileprivate var _underlyingColor: (any Sendable)?'
    if src.include?(anchor) && !src.include?('xcode27MemberwiseFix')
      injected = anchor + "\n\n" \
        "    private init(xcode27MemberwiseFix stringRepresentation: String, underlying: (any Sendable)?) {\n" \
        "        self.stringRepresentation = stringRepresentation\n" \
        "        self._underlyingColor = underlying\n" \
        "    }"
      File.chmod(0o644, paywall_color)
      File.write(paywall_color, src.sub(anchor, injected))
      Pod::UI.puts "Patched RevenueCat PaywallColor.swift for Xcode 27 memberwise init"
    end
  end

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # Xcode 27 yalnızca iOS 15.0+ deployment target'ı destekliyor.
      # Bazı pod'lar eski (9.0–14.0) hedefle geldiği için hepsini 15.0'a zorla.
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'

      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',

        # permission_handler iOS permission flags
        'PERMISSION_MICROPHONE=1',
        'PERMISSION_BLUETOOTH=1',
        'PERMISSION_NOTIFICATIONS=1',
        'PERMISSION_LOCATION=1',
      ]

      # Fix code signing for gRPC's objective_c.framework (0xe8008014)
      config.build_settings['EXPANDED_CODE_SIGN_IDENTITY'] = ""
      config.build_settings['CODE_SIGNING_REQUIRED'] = "NO"
      config.build_settings['CODE_SIGNING_ALLOWED'] = "NO"
    end
  end
end
